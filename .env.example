# Ball Knowledge — environment variables
#
# Real-time 1v1 multiplayer is OPTIONAL. The game is fully playable in
# local demo mode without any backend. To enable cross-device multiplayer,
# create a free Supabase project and fill in the values below, then copy
# this file to ".env" (or ".env.local").
#
# See SUPABASE_SETUP.md for the database tables and policies needed.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
